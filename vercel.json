{
  "version": 2,
  "name": "waleads",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "PAYSTACK_SECRET_KEY": "@paystack-secret-key",
    "PAYSTACK_PUBLIC_KEY": "@paystack-public-key",
    "FIREBASE_SERVICE_ACCOUNT": "@firebase-service-account"
  }
}
